# notion-proxy — local dev env. Copy to .env and fill in.
# In Cloud Run these come from --set-env-vars / --set-secrets, not this file.

# Notion internal integration token. Create one at notion.so/profile/integrations,
# then invite it to the contact DB (and any blog DB you wire up next).
NOTION_TOKEN=secret_replace_me

# Contact form submissions database — already created in OPS / Growth & Marketing.
NOTION_CONTACT_DATABASE_ID=30677f06-0325-4fad-a110-82c26bf6a1fb

# Blog Posts database — read by app/blog_sync.py at build time.
NOTION_BLOG_DATABASE_ID=07926233-654b-4086-998f-40e21366a5ba

# Google reCAPTCHA Enterprise config. Verification authenticates via Application
# Default Credentials, so there's no secret — run `gcloud auth application-default
# login` locally. The SA used by Cloud Run needs roles/recaptchaenterprise.agent.
RECAPTCHA_PROJECT_ID=imperial-rarity-442220-c9
RECAPTCHA_SITE_KEY=replace_me
# Optional — reject assessments scoring below this (0.0 bot — 1.0 human). Default 0.5.
# RECAPTCHA_MIN_SCORE=0.5

# Comma-separated allow-list. http://localhost:4321 is Astro's default dev port.
CORS_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# Optional — pin the Notion API version. Default matches the SDK we'd otherwise pull.
# NOTION_VERSION=2022-06-28
