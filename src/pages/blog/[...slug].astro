---
import { render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getPublishedPosts, formatDate } from '~/lib/blog';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout
  title={`${post.data.title} — ROA`}
  description={post.data.description}
>
  <article class="post">
    <a href="/blog" class="back">← All stories</a>

    <header>
      <div class="meta">
        {post.data.tag && <span class="tag">{post.data.tag}</span>}
        <span class="date">{formatDate(post.data.date)}</span>
        {post.data.minutes && <span class="mins">· {post.data.minutes} min read</span>}
      </div>
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>
      <div class="byline">By {post.data.author}</div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 720px; margin: 0 auto;
    padding: 140px 32px 120px;
  }
  .back {
    display: inline-block; margin-bottom: 36px;
    font-size: 13px; color: var(--c-text-sub);
    transition: color .15s ease;
  }
  .back:hover { color: var(--c-text); }

  header { margin-bottom: 48px; padding-bottom: 32px; border-bottom: 1px solid var(--c-border); }
  .meta { display: flex; gap: 12px; align-items: center; font-size: 12px; color: var(--c-text-muted); }
  .tag { color: var(--c-green); font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; }
  header h1 {
    margin-top: 14px;
    font-size: clamp(34px, 4.6vw, 56px); font-weight: 800;
    letter-spacing: -0.025em; line-height: 1.08;
  }
  .lede {
    margin-top: 18px; font-size: 19px; line-height: 1.5; color: var(--c-text-sub);
  }
  .byline { margin-top: 22px; font-size: 13px; color: var(--c-text-muted); }
</style>

<style is:global>
  .prose { color: var(--c-text); font-size: 17px; line-height: 1.75; }
  .prose > * + * { margin-top: 1.1em; }
  .prose h2 {
    margin-top: 2em;
    font-size: clamp(24px, 2.6vw, 30px); font-weight: 700; letter-spacing: -0.015em; line-height: 1.25;
  }
  .prose h3 {
    margin-top: 1.6em;
    font-size: 20px; font-weight: 700; letter-spacing: -0.01em;
  }
  .prose p { color: var(--c-text-sub); }
  .prose strong { color: var(--c-text); font-weight: 700; }
  .prose em { font-style: italic; }
  .prose a { color: var(--c-green); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { color: var(--c-text); }
  .prose ul, .prose ol { padding-left: 1.4em; color: var(--c-text-sub); }
  .prose li { margin-top: 0.4em; }
  .prose blockquote {
    border-left: 3px solid var(--c-green);
    padding: 4px 0 4px 18px;
    color: var(--c-text-sub); font-style: italic;
  }
  .prose code {
    background: var(--c-card2);
    padding: 2px 6px; border-radius: 4px; font-size: 0.92em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .prose pre {
    background: var(--c-card); border: 1px solid var(--c-border);
    padding: 18px 20px; border-radius: 12px; overflow-x: auto;
    font-size: 13.5px; line-height: 1.6;
  }
  .prose pre code { background: transparent; padding: 0; }
  .prose hr { border: 0; border-top: 1px solid var(--c-border); margin: 2.4em 0; }

  @media (max-width: 720px) {
    .post { padding: 120px 20px 80px; }
  }
</style>
