---
const team = [
  { name: 'Arnav',  role: 'Co-founder & CTO', img: '/assets/arnav.jpg' },
  { name: 'Yago',   role: 'Co-founder & CEO', img: '/assets/yago.jpg'  },
];
---
<section id="team" class="team">
  <div class="inner">
    <header class="reveal">
      <span class="eyebrow">The brigade</span>
      <h2>Built by people who’ve worked the pass.</h2>
      <p>Engineers and operators who know what a kitchen costs in time, money, and humans.</p>
    </header>

    <div class="grid">
      {team.map((p) => (
        <article class="member reveal">
          <img src={p.img} alt={p.name} loading="lazy" />
          <h3>{p.name}</h3>
          <span>{p.role}</span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team { padding: 120px 56px; border-top: 1px solid var(--c-border); }
  .inner { max-width: 1240px; margin: 0 auto; }
  header { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  header h2 {
    margin-top: 14px;
    font-size: clamp(34px, 4vw, 52px); font-weight: 800;
    letter-spacing: -0.02em; line-height: 1.1;
  }
  header p { margin-top: 16px; font-size: 16px; line-height: 1.7; color: var(--c-text-sub); }
  .grid {
    display: grid; gap: 24px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    max-width: 720px; margin: 0 auto;
  }
  .member {
    text-align: center;
    padding: 28px;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: 20px;
  }
  .member img {
    width: 96px; height: 96px; border-radius: 50%;
    object-fit: cover; margin: 0 auto 16px;
    border: 2px solid var(--c-border);
  }
  .member h3 { font-size: 18px; font-weight: 700; }
  .member span { font-size: 13px; color: var(--c-text-sub); margin-top: 4px; display: block; }

  @media (max-width: 820px) {
    .team { padding: 80px 20px; }
  }
</style>
