---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<section id="blog" class="teaser">
  <div class="inner">
    <header class="reveal">
      <span class="eyebrow">Stories from the kitchen</span>
      <h2>Field notes from ROA.</h2>
      <p>How AI is reshaping the back of house, what we’re learning in real kitchens, and the people building it.</p>
    </header>

    {posts.length === 0 ? (
      <div class="empty reveal">More stories soon.</div>
    ) : (
      <div class="grid">
        {posts.map((p) => (
          <a href={`/blog/${p.id}`} class="post reveal">
            <span class="tag">{p.data.tag ?? 'POST'}</span>
            <h3>{p.data.title}</h3>
            <p>{p.data.description}</p>
            <span class="readmore">Read →</span>
          </a>
        ))}
      </div>
    )}

    <div class="all reveal">
      <a class="btn btn-ghost" href="/blog">View all posts</a>
    </div>
  </div>
</section>

<style>
  .teaser { padding: 120px 56px; border-top: 1px solid var(--c-border); }
  .inner { max-width: 1240px; margin: 0 auto; }
  header { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  header h2 {
    margin-top: 14px;
    font-size: clamp(34px, 4vw, 52px); font-weight: 800;
    letter-spacing: -0.02em; line-height: 1.1;
  }
  header p { margin-top: 16px; font-size: 16px; line-height: 1.7; color: var(--c-text-sub); }
  .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }
  .post {
    display: flex; flex-direction: column; gap: 14px;
    padding: 28px;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: 20px;
    transition: transform .2s ease, border-color .2s ease;
    color: var(--c-text);
  }
  .post:hover { transform: translateY(-3px); border-color: var(--c-sage); }
  .tag { font-size: 11px; font-weight: 700; letter-spacing: 0.18em; color: var(--c-green); text-transform: uppercase; }
  .post h3 { font-size: 19px; font-weight: 700; line-height: 1.3; letter-spacing: -0.01em; }
  .post p { font-size: 14px; line-height: 1.6; color: var(--c-text-sub); }
  .readmore { margin-top: auto; font-size: 13px; font-weight: 600; color: var(--c-green); }
  .empty {
    text-align: center; padding: 64px 0; color: var(--c-text-muted);
    border: 1px dashed var(--c-border); border-radius: 20px;
  }
  .all { text-align: center; margin-top: 48px; }

  @media (max-width: 920px) {
    .teaser { padding: 80px 20px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
