---
import RoaMark from '~/components/RoaMark.astro';
---
<div class="intro reveal">
  <div class="badge">Benefits</div>
  <h2>
    <span class="mark"><RoaMark size="1em" strong /></span>
    The Recipe for Operational Excellence.
  </h2>
  <p>ROA fits right into your kitchen routine, sorting out your daily headaches. So, your kitchen runs smoothly, and chefs can just cook.</p>
</div>

<style>
  .intro { text-align: center; }
  .badge {
    display: inline-block;
    padding: 10px 22px;
    border-radius: 8px;
    background: var(--c-pillar-pill-bg);
    color: var(--c-pillar-pill-ink);
    font-size: 14px; font-weight: 700; letter-spacing: 1.5px;
    box-shadow: 0 10px 24px -12px rgba(20,40,18,0.25);
    text-transform: uppercase;
    margin-bottom: 32px;
  }
  h2 {
    font-size: clamp(40px, 5.5vw, 72px);
    font-weight: 800; line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--c-text);
    max-width: 1000px; margin: 0 auto;
  }
  .mark { color: var(--c-green); display: inline-flex; vertical-align: baseline; margin-right: 14px; }
  p {
    font-size: 18px; color: var(--c-text-muted);
    margin: 24px auto 0; line-height: 1.6;
    max-width: 640px;
  }
</style>
