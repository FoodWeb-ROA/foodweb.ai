---
import { mdiChefHat } from '@mdi/js';

const TESTIMONIALS = [
  { role: 'Executive Chef', quote: "I've always dreamed of a tool that creates the production plan for my team at the end of every service." },
  { role: 'Head Chef', quote: "This type of intuitive software is what the kitchen needs." },
  { role: 'Head Chef', quote: "ROA's flow is frictionless recipes to action." },
];
---
<section class="marquee">
  <div class="eyebrow-row">
    <span class="dot-icon">
      <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
        <circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 3" />
      </svg>
    </span>
    <span class="eyebrow-text">Live from ROA kitchens</span>
  </div>

  <div class="cards-grid">
    {TESTIMONIALS.map((t) => (
      <div class="note">
        <div class="avatar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden>
            <path d={mdiChefHat} />
          </svg>
        </div>
        <div class="body">
          <div class="meta">
            <span class="who">{t.role}</span>
          </div>
          <div class="quote">"{t.quote}"</div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .marquee {
    padding: 90px 0 100px;
    border-top: 1px solid var(--c-border);
  }
  .eyebrow-row {
    text-align: center; margin-bottom: 36px;
    display: flex; justify-content: center; align-items: center; gap: 10px;
  }
  .dot-icon { color: var(--c-green); display: inline-flex; align-items: center; }
  .eyebrow-text {
    font-size: 11px; font-weight: 700; letter-spacing: 2.5px;
    color: var(--c-text-muted); text-transform: uppercase;
  }

  .cards-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    padding: 0 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .note {
    width: 340px;
    padding: 14px 18px;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: 14px;
    box-shadow: 0 18px 36px -22px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.04);
    display: flex; align-items: flex-start; gap: 12px;
  }
  .avatar {
    flex-shrink: 0;
    width: 38px; height: 38px; border-radius: 50%;
    background: linear-gradient(135deg, rgba(74,143,74,0.28), rgba(74,143,74,0.06));
    border: 1px solid var(--c-border);
    display: flex; align-items: center; justify-content: center;
    color: var(--c-green);
  }
  .body { flex: 1; min-width: 0; }
  .meta { display: flex; align-items: baseline; gap: 8px; }
  .who { font-size: 13px; font-weight: 700; color: var(--c-text); white-space: nowrap; }
  .quote {
    font-size: 13.5px; color: var(--c-text-sub); font-weight: 400;
    margin-top: 6px; line-height: 1.45;
  }
</style>
