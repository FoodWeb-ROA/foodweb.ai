---
interface Props {
  src: string;
  alt?: string;
  width?: number;
}
const { src, alt = '', width = 160 } = Astro.props;
---
<div class="phone-shot" style={`width:${width}px`}>
  <div class="phone-shot-notch"></div>
  <img src={src} alt={alt} loading="lazy" />
</div>

<style>
  .phone-shot {
    position: relative;
    border-radius: 34px;
    background: #0b1e08;
    border: 2px solid rgba(100,130,100,0.3);
    box-shadow: 0 28px 56px rgba(0,0,0,0.65), inset 0 1px 0 rgba(255,255,255,0.05);
    overflow: hidden;
    flex-shrink: 0;
  }
  .phone-shot-notch {
    position: absolute; top: 0; left: 50%;
    transform: translateX(-50%);
    width: 72px; height: 22px;
    background: #0b1e08;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    z-index: 3;
  }
  .phone-shot img { width: 100%; display: block; }
</style>
